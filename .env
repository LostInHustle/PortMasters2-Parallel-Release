# SQLite: a single file, no database server to install or run. Prisma 7
# resolves a relative file: path against the project root (prisma.config.ts),
# not against prisma/schema.prisma the way older Prisma versions did, so the
# path is spelled out here to still land in prisma/dev.db.
# For production, point this at an absolute path on a persistent volume
# (see docs/deployment.md).
DATABASE_URL=file:./prisma/dev.db
