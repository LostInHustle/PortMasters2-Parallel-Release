{
  "name": "portmasters2-parallel-release",
  "version": "0.2.0",
  "private": true,
  "engines": {
    "node": ">=20.19.0"
  },
  "packageManager": "npm@10.8.2",
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "tsx watch server.ts",
    "build": "prisma generate && next build",
    "start": "prisma migrate deploy && NODE_ENV=production tsx server.ts",
    "lint": "eslint .",
    "test:unit": "tsx scripts/tests/unit.game.ts",
    "test:effects": "tsx scripts/tests/effects.audit.ts",
    "test:integration": "tsx scripts/tests/integration.voyage.ts",
    "test:harbor": "tsx scripts/tests/integration.harbor.ts",
    "test:convoy": "tsx scripts/tests/integration.convoy.ts",
    "test:backing": "tsx scripts/tests/integration.backing.ts",
    "test": "npm run test:unit && npm run test:effects && npm run test:integration && npm run test:harbor && npm run test:convoy && npm run test:backing",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset",
    "db:clean": "tsx scripts/reset-db.ts"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-tooltip": "^1.2.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.2",
    "lucide-react": "^0.525.0",
    "next": "^16.2.9",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.6",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.0.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.1.1",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "tw-animate-css": "^1.3.5",
    "typescript": "^5"
  }
}
